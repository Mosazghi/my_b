{
  "name": "cpp-sfml-dev",
  "build": {
    "dockerfile": "../Dockerfile",
  },
  "containerEnv": {
    "DISPLAY": "host.docker.internal:0.0",
  },
  "customizations": {
    "zed": {
      "settings": {
        "lsp": {
          "clangd": {
            "initialization_options": {
              "compilationDatabasePath": "build",
            },
          },
        },
      },
    },
  },
}
